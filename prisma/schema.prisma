generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  free
  pro
  premium
  team
}

enum UserRole {
  member
  admin
  support
}

enum AccountStatus {
  incomplete
  active
  trialing
  past_due
  unpaid
  canceled
  incomplete_expired
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  unpaid
  canceled
  paused
}

enum SupportTicketCategory {
  billing
  technical
  product
  account
  other
}

enum SupportTicketPriority {
  low
  medium
  high
  urgent
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
}

enum StripeEventProcessingStatus {
  pending
  processed
  failed
  skipped
}

enum SessionMode {
  resume
  linkedin
  interview
  career
  confidence
  recap
}

enum SessionStatus {
  ready
  live
  reviewing
  complete
  failed
}

enum MessageRole {
  system
  user
  assistant
  tool
}

enum DocumentType {
  resume
  linkedin
  cover_letter
  interview_notes
  miscellaneous
}

enum DocumentStatus {
  uploaded
  parsing
  indexed
  reviewed
  failed
}

enum ReviewType {
  resume
  linkedin
}

enum FeedbackType {
  thumbs_up
  thumbs_down
  rating
}

model User {
  id                  String         @id @default(uuid()) @db.Uuid
  email               String         @unique
  externalAuthId      String?        @unique
  passwordHash        String?
  firstName           String?
  lastName            String?
  locale              String?
  planTier            PlanTier       @default(free)
  role                UserRole       @default(member)
  accountId           String?        @db.Uuid
  consentPersonalize  Boolean        @default(true)
  consentAnalytics    Boolean        @default(true)
  marketingOptIn      Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  account             Account?       @relation("AccountMembers", fields: [accountId], references: [id], onDelete: SetNull)
  ownedAccounts       Account[]      @relation("AccountOwner")
  coachProfile        CoachProfile?
  appSessions         AppSession[]
  passwordResetTokens PasswordResetToken[]
  sessions            CoachingSession[]
  documents           Document[]
  actionPlans         ActionPlan[]
  memories            Memory[]
  usageEvents         UsageEvent[]
  feedbackEntries     Feedback[]
  supportTickets      SupportTicket[] @relation("SupportTicketReporter")
  assignedTickets     SupportTicket[] @relation("SupportTicketAssignee")
  appEvents           AppEvent[]
  adminNotes          AdminNote[]    @relation("AdminNoteAuthor")
  tokenUsageEntries   AiTokenUsage[]
}

model Account {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  ownerUserId    String        @db.Uuid
  status         AccountStatus @default(incomplete)
  paymentIssue   Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ownerUser      User          @relation("AccountOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  users          User[]        @relation("AccountMembers")
  subscription   Subscription?
  supportTickets SupportTicket[]
  appEvents      AppEvent[]
  adminNotes     AdminNote[]
  stripeEvents   StripeEvent[]
  tokenUsageEntries AiTokenUsage[]

  @@index([ownerUserId])
  @@index([status])
}

model Subscription {
  id                  String             @id @default(uuid()) @db.Uuid
  accountId           String             @unique @db.Uuid
  stripeCustomerId    String             @unique
  stripeSubscriptionId String            @unique
  stripePriceId       String?
  planName            String?
  status              SubscriptionStatus @default(incomplete)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  canceledAt          DateTime?
  trialEnd            DateTime?
  paymentIssue        Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  account             Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([currentPeriodEnd])
}

model AppSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoachProfile {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  currentRole      String?
  targetRole       String?
  experienceLevel  String?
  geography        String?
  goals            Json
  painPoints       Json
  preferences      Json?
  onboardingAnswers Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachingSession {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid
  mode              SessionMode
  status            SessionStatus    @default(ready)
  title             String
  summary           String?          @db.Text
  actionPlanDraft   Json?
  transcriptSummary Json?
  realtimeProvider  String?
  realtimeSessionId String?
  avatarProvider    String?
  avatarSessionId   String?
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          SessionMessage[]
  documents         Document[]
  reviews           DocumentReview[]
  feedbackEntries   Feedback[]

  @@index([userId, createdAt])
  @@index([status])
}

model SessionMessage {
  id         String          @id @default(uuid()) @db.Uuid
  sessionId  String          @db.Uuid
  role       MessageRole
  content    String          @db.Text
  toolName   String?
  metadata   Json?
  createdAt  DateTime        @default(now())
  session    CoachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Document {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  sessionId       String?          @db.Uuid
  type            DocumentType
  status          DocumentStatus   @default(uploaded)
  fileName        String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  extractedText   String?          @db.Text
  extractedJson   Json?
  pageMap         Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session         CoachingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  reviews         DocumentReview[]

  @@index([userId, createdAt])
  @@index([sessionId])
}

model DocumentReview {
  id                    String           @id @default(uuid()) @db.Uuid
  sessionId             String?          @db.Uuid
  documentId            String           @db.Uuid
  type                  ReviewType
  overallScore          Int?
  atsScore              Int?
  clarityScore          Int?
  impactScore           Int?
  positioningScore      Int?
  findings              Json
  rewrittenBullets      Json?
  tailoringSuggestions  Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  session               CoachingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  document              Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([sessionId])
}

model ActionPlan {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  title        String
  details      String?  @db.Text
  priority     String
  dueAt        DateTime?
  completedAt  DateTime?
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Memory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  label       String
  content     String   @db.Text
  relevance   String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UsageEvent {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  eventType   String
  quantity    Int      @default(1)
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType])
}

model SupportTicket {
  id            String                @id @default(uuid()) @db.Uuid
  accountId     String                @db.Uuid
  userId        String?               @db.Uuid
  subject       String
  description   String                @db.Text
  category      SupportTicketCategory @default(other)
  priority      SupportTicketPriority @default(medium)
  status        SupportTicketStatus   @default(open)
  assignedToId  String?               @db.Uuid
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  resolvedAt    DateTime?
  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reporter      User?                 @relation("SupportTicketReporter", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo    User?                 @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  adminNotes    AdminNote[]

  @@index([accountId, createdAt])
  @@index([status, priority])
  @@index([assignedToId])
}

model AppEvent {
  id           String    @id @default(uuid()) @db.Uuid
  accountId    String?   @db.Uuid
  userId       String?   @db.Uuid
  eventName    String
  metadataJson Json?
  createdAt    DateTime  @default(now())
  account      Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([eventName, createdAt])
}

model AdminNote {
  id              String         @id @default(uuid()) @db.Uuid
  accountId       String         @db.Uuid
  userId          String         @db.Uuid
  supportTicketId String?        @db.Uuid
  note            String         @db.Text
  createdAt       DateTime       @default(now())
  account         Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  author          User           @relation("AdminNoteAuthor", fields: [userId], references: [id], onDelete: Cascade)
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([supportTicketId, createdAt])
}

model StripeEvent {
  id          String                      @id @default(uuid()) @db.Uuid
  stripeEventId String                    @unique
  eventType   String
  status      StripeEventProcessingStatus @default(pending)
  accountId   String?                     @db.Uuid
  payload     Json
  errorMessage String?
  processedAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  account     Account?                    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([status, createdAt])
}

model AiTokenUsage {
  id           String    @id @default(uuid()) @db.Uuid
  accountId    String?   @db.Uuid
  userId       String?   @db.Uuid
  provider     String    @default("openai")
  model        String
  featureName  String?
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  totalTokens  Int       @default(0)
  metadataJson Json?
  createdAt    DateTime  @default(now())
  account      Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
  @@index([model, createdAt])
}

model Feedback {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  sessionId   String?          @db.Uuid
  type        FeedbackType
  rating      Int?
  note        String?          @db.Text
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     CoachingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  category    String
  description String?
  avgSalary   String?
  isPopular   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isPopular])
  @@index([category])
}

model Company {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique
  slug          String   @unique
  logoUrl       String?
  website       String?
  category      String
  employeeCount String?
  headquarters  String?
  isPopular     Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([isPopular])
  @@index([category])
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
