# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (no trailing slash). Used in emails and sitemap.
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Secret used for HMAC signing, session tokens, etc. Generate with:
#   openssl rand -hex 32
APP_SECRET=change-me-to-a-random-32-char-secret

# ─── Database (Neon / Postgres) ───────────────────────────────────────────────
# Pooled connection URL (used at runtime)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Unpooled connection URL (used by Prisma migrations)
# On Netlify: set NETLIFY_DATABASE_URL_UNPOOLED
# DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for each plan (from Stripe dashboard)
STRIPE_PRICE_ID=price_...

# Optional: override price amounts in cents (defaults to Stripe prices)
# PLAN_AMOUNT_PRO_CENTS=2900
# PLAN_AMOUNT_PREMIUM_CENTS=4900
# PLAN_AMOUNT_TEAM_CENTS=9900

# Optional: number of trial days
# STRIPE_TRIAL_DAYS=7

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model used for most AI features (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_QUALITY=gpt-4o

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# From address for transactional emails
RESEND_FROM=Zari <no-reply@your-domain.com>

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ─── ElevenLabs (optional — voice interview feature) ─────────────────────────
# ELEVENLABS_API_KEY=

# ─── Groq (optional — faster transcription) ──────────────────────────────────
# GROQ_API_KEY=
# GROQ_MODEL=whisper-large-v3-turbo

# ─── Coach Admin ──────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to access /coach-admin
COACH_ADMIN_EMAIL_ALLOWLIST=admin@your-domain.com

# Password for /coach-admin login
COACH_ADMIN_PASSWORD=change-me

# Dev only: auto-login to coach admin as this email (do NOT set in production)
# COACH_ADMIN_BETA_AUTO_LOGIN=

# ─── Credits / Tokens ─────────────────────────────────────────────────────────
# How many AI tokens equal one credit (default: 1000)
# BILLING_TOKENS_PER_CREDIT=1000

# Token limits per plan (overrides Prisma defaults if set)
# PLAN_TOKEN_LIMIT_FREE=10000
# PLAN_TOKEN_LIMIT_SEARCH=50000
# PLAN_TOKEN_LIMIT_GROWTH=150000
# PLAN_TOKEN_LIMIT_EXECUTIVE=500000

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Secret for POST /api/cron/cleanup. Set this and pass as Bearer token from your cron provider.
# Generate with: openssl rand -hex 24
# CRON_SECRET=

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Public key for Logo.dev (company logo images)
# NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# Brave Search API key (company/role search features)
# BRAVE_API_KEY=
